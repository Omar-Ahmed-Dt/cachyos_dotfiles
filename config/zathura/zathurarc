#my config

# set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
# set page-padding 1
# set selection-clipboard clipboard
map ^u scroll half-up
map ^d scroll half-down
map d toggle_page_mode
map r reload
map R rotate
map <C-j> scroll full-down
map <C-k> scroll full-up
# map K zoom in 
map _ zoom out
map i recolor
map p print
map gg goto top

# colors: gruvbox dark
set default-bg                  "#282828"
set default-fg                  "#3C3836"

set statusbar-fg                "#EBDBB2"
set statusbar-bg                "#504945"

set inputbar-bg                 "#282828"
set inputbar-fg                 "#8EC07C"

set notification-bg             "#282828"
set notification-fg             "#8EC07C"

set notification-error-bg       "#282828"
set notification-error-fg       "#CC241D"

set notification-warning-bg     "#282828"
set notification-warning-fg     "#D79921"

set highlight-color             "#D79921"
set highlight-active-color      "#458588"

set completion-bg               "#3C3836"
set completion-fg               "#83A598"

set completion-highlight-fg     "#FBF1C7"
set completion-highlight-bg     "#458588"

set recolor-lightcolor          "#282828"
set recolor-darkcolor           "#EBDBB2"

# set recolor                     "true"
set recolor-keephue             "true"

# Gruvbox Theme
set $bg         #1d2021
set $bg_soft    #282828
set $bg_alt     #32302f
set $fg         #ebdbb2
set $fg_dim     #a89984
set $red        #cc241d
set $green      #98971a
set $yellow     #d79921
set $blue       #458588
set $purple     #b16286
set $aqua       #689d68

# border style
gaps inner 3
gaps outer 3
default_border pixel 1
default_floating_border normal
smart_borders on
focus_on_window_activation smart
default_orientation horizontal

bar {
    swaybar_command waybar
}

client.focused          $blue   $bg_soft $fg     $yellow $blue
client.unfocused        $bg_alt $bg      $fg_dim $bg_alt $bg_alt
client.focused_inactive $bg_alt $bg      $fg_dim $bg_alt $bg_alt
client.urgent           $red    $red     $fg     $red $red
client.background       $bg



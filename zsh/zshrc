# topdf() { local f="${1%.tex}"; latexmk -pdf "$1" && latexmk -c && qpdf --linearize --replace-input "$f.pdf" || { latexmk -C "$1"; return 1; }; }

topdf() {
  if [[ -z "$1" ]]; then
    echo "Usage: topdf <file[.tex]> [output_name]"
    echo "  topdf resume                      → resume.pdf"
    echo "  topdf resume x                    → x.pdf"
    return 1
  fi

  local source="${1%.tex}.tex"              # accept "resume" or "resume.tex"
  local base="${source%.tex}"               # filename without extension
  local output="${2:-$base}"                # use 2nd arg, or fall back to source name
  output="${output%.pdf}"                   # strip .pdf if user added it
  local pdf="${output}.pdf"

  latexmk -pdf -jobname="$output" "$source" \
    && latexmk -c -jobname="$output" "$source" \
    && qpdf --linearize --replace-input "$pdf" \
    || { latexmk -C -jobname="$output" "$source"; return 1; }

  echo "✓ Created: $pdf"
}


# yazi cd-on-exit
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    cd "$cwd"
  fi
  rm -f "$tmp"
}

# ============================================================
# cns - Change Kubernetes Namespace via fzf
# ============================================================
# Add this to your ~/.zshrc file, then run: source ~/.zshrc
#
# Requirements:
#   - kubectl  (https://kubernetes.io/docs/tasks/tools/)
#   - fzf      (https://github.com/junegunn/fzf)
#
# Usage:
#   cns           # Opens fzf menu with all namespaces
#   cns <name>    # Switches directly to <name> if provided
# ============================================================

cns() {
  # Ensure required tools are installed
  if ! command -v kubectl >/dev/null 2>&1; then
    echo "❌ kubectl is not installed or not in PATH"
    return 1
  fi
  if ! command -v fzf >/dev/null 2>&1; then
    echo "❌ fzf is not installed or not in PATH"
    return 1
  fi

  # Verify cluster connectivity
  if ! kubectl cluster-info >/dev/null 2>&1; then
    echo "❌ Cannot reach Kubernetes cluster. Check your kubeconfig/context."
    return 1
  fi

  local current_ns
  current_ns=$(kubectl config view --minify --output 'jsonpath={..namespace}' 2>/dev/null)
  [[ -z "$current_ns" ]] && current_ns="default"

  local selected_ns

  # If an argument is given, use it directly (skip fzf)
  if [[ -n "$1" ]]; then
    selected_ns="$1"
  else
    # Fetch namespace names only and pipe into fzf
    selected_ns=$(
      kubectl get namespaces -o jsonpath='{.items[*].metadata.name}' \
      | tr ' ' '\n' \
      | fzf \
          --prompt="🔀 Switch namespace > " \
          --header="Current namespace: ${current_ns}" \
          --height=40% \
          --layout=reverse \
          --border
    )
  fi

  # User cancelled fzf (Esc / Ctrl-C)
  if [[ -z "$selected_ns" ]]; then
    echo "⚠️  No namespace selected."
    return 1
  fi

  # No-op if already on the chosen namespace
  if [[ "$selected_ns" == "$current_ns" ]]; then
    echo "✅ Already on namespace: $selected_ns"
    return 0
  fi

  # Switch the current context's namespace
  if kubectl config set-context --current --namespace="$selected_ns" >/dev/null 2>&1; then
    echo "✅ Switched namespace: $current_ns → $selected_ns"
  else
    echo "❌ Failed to switch to namespace: $selected_ns"
    return 1
  fi
}

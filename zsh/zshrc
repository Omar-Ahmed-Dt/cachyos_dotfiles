# Ctrl+r FZF HISTORY (improved)
fzf-history() {
  local selected
  selected=$(
    fc -rl 1 \
    | sed 's/^ *[0-9]*\*\? *//' \
    | awk '!seen[$0]++' \
    | fzf \
        --height 70% \
        --reverse \
        --prompt='History> ' \
        --query="$LBUFFER" \
        --no-sort \
        --exact \
        --bind 'ctrl-y:execute-silent(echo -n {+} | wl-copy)+abort' \
        --header='enter: paste | ctrl-y: copy'
  )
  if [[ -z $selected ]]; then
    zle redisplay
    return
  fi
  LBUFFER="$selected"
  zle redisplay
}
zle -N fzf-history
bindkey '^R' fzf-history

# Alt+p - Show detailed current directory info
pwd-widget() {
  # Do nothing if we are in HOME
  if [[ "$PWD" == "$HOME" ]]; then
    zle redisplay
    return
  fi

  echo ""
  echo -e "\033[1;36m📁 Current Directory:\033[0m" "$PWD"

  # Show number of files
  local file_count
  file_count=$(ls -1 | wc -l)
  echo -e "\033[1;33m📊 Items: $file_count\033[0m"

  # Show directory size
  local dir_size
  dir_size=$(du -sh . 2>/dev/null | cut -f1)
  echo -e "\033[1;32m💾 Size: $dir_size\033[0m"

  # Show git branch if in a git repo
  if git rev-parse --git-dir > /dev/null 2>&1; then
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    echo -e "\033[1;35m🌿 Git: $branch\033[0m"
  fi

  zle reset-prompt
}

zle -N pwd-widget
bindkey '^[p' pwd-widget

